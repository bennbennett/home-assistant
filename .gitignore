# Home Assistant sensitive files
secrets.yaml
.google_maps_location_sharing.cookies.*
.shopping_list.json

# Database files
*.db
*.db-shm
*.db-wal

# Log files
*.log
*.log.*
home-assistant.log.fault

# Cache and temporary files
.storage/
deps/
tts/
.cloud/
__pycache__/
*.pyc

# System files
.DS_Store
*.swp
*.swo
*~

# Backup files
*.backup*
*.bak

# Nest tokens and other auth files
nest/

# HACS-managed integrations — re-installed by HACS, not source
custom_components/

# HACS-installed Lovelace frontend cards — also HACS-managed
www/community/

# HA brand/icon cache
.cache/

# Credentials / API tokens
.mealie_token

# Personal screenshot dump (not source)
screenshots/

# Project notes — track .md docs but not bulky screenshots
mobile-dashboard-project/*.png

# Lock files
.HA_VERSION
.ha_run.lock

# Environment and credentials
.env

# gstack working files
.gstack/

# Empty placeholder directories
ha_config/

# Tab title (shell state)
.tab-title
